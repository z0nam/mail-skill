#!/usr/bin/env bash
# 전체 시크릿을 평문으로 복호화 → $EDITOR 로 열기 → 저장 시 모든 recipient 로 재암호화.
# 새 기계 공개키를 recipients.txt 에 추가한 뒤, 그냥 한 번 저장하면 그 기계도 복호화 가능.
set -euo pipefail
_self="$0"; while [ -L "$_self" ]; do _t="$(readlink "$_self")"; case "$_t" in /*) _self="$_t";; *) _self="$(dirname "$_self")/$_t";; esac; done
REPO="${MAIL_SKILL_REPO:-$(cd "$(dirname "$_self")/.." && pwd)}"
KEY="${MAIL_MCP_AGE_KEY:-$HOME/.config/mail-mcp/age-key.txt}"
SECRETS="$REPO/secrets/secrets.age"
RECIP="$REPO/secrets/recipients.txt"
[ -s "$RECIP" ] || { echo "recipients.txt 비어있음" >&2; exit 1; }
tmp="$(mktemp)"; trap 'rm -f "$tmp"' EXIT
if [ -f "$SECRETS" ]; then age -d -i "$KEY" "$SECRETS" > "$tmp"; fi
"${EDITOR:-vi}" "$tmp"
age -R "$RECIP" -o "$SECRETS" "$tmp"
echo "secrets 재암호화 완료 (recipient $(grep -vc '^#' "$RECIP")개)"
