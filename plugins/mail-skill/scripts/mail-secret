#!/usr/bin/env bash
# mail-mcp 시크릿 리졸버 — Himalaya 의 auth.cmd 가 호출한다.
# age 암호화 파일(secrets/secrets.age)에서 <name> 의 값을 꺼내 stdout 으로 출력(개행 없음).
# macOS/Linux 공통. 기계별 복호화 키는 ~/.config/mail-mcp/age-key.txt (동기화 안 함).
set -euo pipefail
name="${1:?usage: mail-secret <name>}"
_self="$0"; while [ -L "$_self" ]; do _t="$(readlink "$_self")"; case "$_t" in /*) _self="$_t";; *) _self="$(dirname "$_self")/$_t";; esac; done
REPO="${MAIL_SKILL_REPO:-$(cd "$(dirname "$_self")/.." && pwd)}"
KEY="${MAIL_SKILL_AGE_KEY:-$HOME/.config/mail-skill/age-key.txt}"
if [ -n "${MAIL_SKILL_SECRETS:-}" ]; then SECRETS="$MAIL_SKILL_SECRETS"
elif [ -f "$REPO/secrets/secrets.age" ]; then SECRETS="$REPO/secrets/secrets.age"
else SECRETS="$HOME/.config/mail-skill/secrets.age"; fi
[ -f "$KEY" ]     || { echo "mail-secret: age 키 없음: $KEY (bootstrap.sh 실행)" >&2; exit 1; }
[ -f "$SECRETS" ] || { echo "mail-secret: secrets 없음: $SECRETS" >&2; exit 1; }
out="$(age -d -i "$KEY" "$SECRETS" 2>/dev/null \
  | awk -v n="$name" 'index($0,n"=")==1{print substr($0,length(n)+2);f=1;exit} END{exit f?0:3}')" \
  || { echo "mail-secret: 시크릿 '$name' 없음(또는 복호화 실패)" >&2; exit 3; }
printf '%s' "$out"
