#!/usr/bin/env bash
# 시크릿 1개 추가/갱신 후 recipients.txt 의 모든 공개키로 재암호화.
# 값은 인자로 받지 않는다(셸 히스토리/노출 방지).
#   secret-set <name>           # 숨김 프롬프트로 입력
#   secret-set <name> --stdin   # stdin 에서 값 1줄 읽음 (파이프용)
set -euo pipefail
name="${1:?usage: secret-set <name> [--stdin]}"
mode="${2:-prompt}"
_self="$0"; while [ -L "$_self" ]; do _t="$(readlink "$_self")"; case "$_t" in /*) _self="$_t";; *) _self="$(dirname "$_self")/$_t";; esac; done
REPO="${MAIL_SKILL_REPO:-$(cd "$(dirname "$_self")/.." && pwd)}"
KEY="${MAIL_SKILL_AGE_KEY:-$HOME/.config/mail-skill/age-key.txt}"
if [ -n "${MAIL_SKILL_SECRETS:-}" ]; then SECRETS="$MAIL_SKILL_SECRETS"
elif [ -f "$REPO/secrets/recipients.txt" ]; then SECRETS="$REPO/secrets/secrets.age"
else SECRETS="$HOME/.config/mail-skill/secrets.age"; fi
RECIP="$(dirname "$SECRETS")/recipients.txt"
[ -s "$RECIP" ] || { echo "recipients.txt 비어있음 — 공개키 등록 먼저(bootstrap)" >&2; exit 1; }

if [ "$mode" = "--stdin" ]; then
  IFS= read -r val || true            # 개행 없는 stdin(EOF) 허용
else
  printf 'value for %s: ' "$name" >&2; IFS= read -rs val || true; echo >&2
fi
[ -n "$val" ] || { echo "빈 값 거부" >&2; exit 1; }

tmp="$(mktemp)"; new="$(mktemp)"; trap 'rm -f "$tmp" "$new"' EXIT
if [ -f "$SECRETS" ]; then age -d -i "$KEY" "$SECRETS" > "$tmp"; fi
grep -v "^${name}=" "$tmp" > "$new" 2>/dev/null || true
printf '%s=%s\n' "$name" "$val" >> "$new"
age -R "$RECIP" -o "$SECRETS" "$new"
echo "set '$name' → recipient $(grep -vc '^#' "$RECIP")개" >&2
